@model IEnumerable<TechCoreSolutions.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-bold text-primary">Employee Management</h1>
        <button onclick="openModal('@Url.Action("Create")')" class="btn btn-success shadow-sm rounded-pill px-4">
            <i class="bi bi-person-plus-fill me-1"></i> Add Employee
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-2">
                <div class="col-md-7">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                               class="form-control border-start-0 shadow-none" placeholder="Search by name or position..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="department" class="form-select shadow-none" onchange="this.form.submit()">
                        <option value="">All Departments</option>
                        @foreach (var dept in (List<string>)ViewBag.Departments ?? new List<string>())
                        {
                            if (dept == (string)ViewData["CurrentDept"])
                            {
                                <option value="@dept" selected>@dept</option>
                            }
                            else
                            {
                                <option value="@dept">@dept</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">Search</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Full Name</th>
                    <th>Position</th>
                    <th>Department</th>
                    <th>Daily Rate</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="ps-4 text-muted small">#@item.EmployeeID</td>
                    <td>
                        <div class="fw-bold text-dark">@item.FullName</div>
                        <div class="text-muted extra-small" style="font-size: 0.75rem;">Hired: @item.HireDate.ToShortDateString()</div>
                    </td>
                    <td><span class="badge rounded-pill bg-info text-dark fw-normal">@item.Position</span></td>
                    <td>@item.Department</td>
                    <td class="fw-bold text-success">₱@item.DailyRate.ToString("N2")</td>
                    <td class="text-center">
                        <div class="btn-group">
                            <button onclick="openModal('@Url.Action("Details", new { id = item.EmployeeID })')" 
                                    class="btn btn-sm btn-outline-primary border-0" 
                                    data-bs-toggle="tooltip" title="View Details">
                                <i class="bi bi-eye-fill fs-5"></i>
                            </button>

                            <button onclick="openModal('@Url.Action("Edit", new { id = item.EmployeeID })')" 
                                    class="btn btn-sm btn-outline-warning border-0" 
                                    data-bs-toggle="tooltip" title="Edit Employee">
                                <i class="bi bi-pencil-square fs-5"></i>
                            </button>

                            <button onclick="openModal('@Url.Action("Delete", new { id = item.EmployeeID })')" 
                                    class="btn btn-sm btn-outline-danger border-0" 
                                    data-bs-toggle="tooltip" title="Delete Employee">
                                <i class="bi bi-trash3-fill fs-5"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="employeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div id="modalContent" class="modal-content border-0 shadow-lg rounded-4">
            </div>
    </div>
</div>

@section Scripts {
    <script>
        // Combined and fixed Scripts section
        
        // 1. Modal Loading Function
        function openModal(url) {
            $.ajax({
                url: url,
                type: 'GET',
                headers: { "X-Requested-With": "XMLHttpRequest" }, // Necessary for Controller check
                success: function (data) {
                    $('#modalContent').html(data);
                    $('#employeeModal').modal('show');
                },
                error: function () {
                    alert("Failed to load form. Ensure partial views exist in Views/Employees/");
                }
            });
        }

        // 2. Re-bind validation for dynamically loaded forms
        $(document).ajaxComplete(function() {
            if ($.validator && $.validator.unobtrusive) {
                $.validator.unobtrusive.parse('form');
            }
            
            // Re-initialize tooltips for any new elements
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });

        // 3. Initial Tooltip Setup
        document.addEventListener("DOMContentLoaded", function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });
    </script>
}