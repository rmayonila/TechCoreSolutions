@model TechCoreSolutions.Models.Employee
<div class="modal-header border-0 pb-0">
    <h4 class="modal-title fw-bold" id="modalTitle">Employee Form</h4>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<form asp-action="@(Model?.EmployeeID > 0 ? "Edit" : "Create")" method="post">
    <div class="modal-body p-4">
        @if(Model?.EmployeeID > 0) 
        { 
            <input type="hidden" asp-for="EmployeeID" /> 
        }

        <div class="mb-3">
            <label class="form-label fw-semibold small text-muted text-uppercase">Employee ID</label>
            <input class="form-control bg-light border-0 shadow-none text-muted" value="@(Model?.EmployeeID > 0 ? $"#{Model.EmployeeID}" : "Auto-generated")" readonly />
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FirstName" class="form-label fw-semibold small text-muted text-uppercase">First Name</label>
                <input asp-for="FirstName" class="form-control bg-light border-0 shadow-none" placeholder="e.g. John" />
                <span asp-validation-for="FirstName" class="text-danger extra-small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastName" class="form-label fw-semibold small text-muted text-uppercase">Last Name</label>
                <input asp-for="LastName" class="form-control bg-light border-0 shadow-none" placeholder="e.g. Doe" />
                <span asp-validation-for="LastName" class="text-danger extra-small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Position" class="form-label fw-semibold small text-muted text-uppercase">Position</label>
                <input asp-for="Position" class="form-control bg-light border-0 shadow-none" placeholder="e.g. Manager" />
                <span asp-validation-for="Position" class="text-danger extra-small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Department" class="form-label fw-semibold small text-muted text-uppercase">Department</label>
                <input asp-for="Department" class="form-control bg-light border-0 shadow-none" placeholder="e.g. IT" />
                <span asp-validation-for="Department" class="text-danger extra-small"></span>
            </div>
            <div class="col-12">
                <label asp-for="DailyRate" class="form-label fw-semibold small text-muted text-uppercase">Daily Rate (₱)</label>
                <input asp-for="DailyRate" class="form-control bg-light border-0 shadow-none" type="number" step="0.01" />
                <span asp-validation-for="DailyRate" class="text-danger extra-small"></span>
            </div>
        </div>
    </div>
    <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-light px-4 rounded-pill fw-bold text-muted" data-bs-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-success px-4 rounded-pill fw-bold shadow-sm">Save Employee</button>
    </div>
</form>
