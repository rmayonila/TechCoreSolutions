@model TechCoreSolutions.Models.Payroll

@{
    ViewData["Title"] = "Payroll Details";
}

<div class="container mt-4">
    <div class="mb-4">
        <h1 class="display-6 fw-bold text-primary mb-0">Payroll Details</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item active">#@Model.PayrollID</li>
            </ol>
        </nav>
    </div>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-muted"><i class="bi bi-person-badge me-2"></i>Employee Information</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-person text-primary fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-0">@Model.Employee?.FullName</h4>
                        <span class="badge bg-info text-dark">@Model.Employee?.Position</span>
                    </div>

                    <div class="list-group list-group-flush border-top">
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 bg-transparent">
                            <span class="text-muted small">Department</span>
                            <span class="fw-bold">@Model.Employee?.Department</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 bg-transparent">
                            <span class="text-muted small">Daily Rate</span>
                            <span class="fw-bold text-primary">₱@Model.Employee?.DailyRate.ToString("N2")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 bg-transparent">
                            <span class="text-muted small">Pay Date</span>
                            <span class="fw-bold">@Model.Date.ToString("MMMM dd, yyyy")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 bg-transparent">
                            <span class="text-muted small">Days Worked</span>
                            <span class="badge rounded-pill bg-dark">@Model.DaysWorked Days</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm mb-4 h-100">
                <div class="card-header bg-primary text-white py-3 border-0">
                    <h5 class="mb-0 fw-bold text-center"><i class="bi bi-wallet2 me-2"></i>Earnings Summary</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row text-center">
                        <div class="col-6 border-end">
                            <label class="text-muted small text-uppercase fw-bold d-block">Gross Income</label>
                            <h3 class="text-dark fw-bold">₱@Model.GrossPay.ToString("N2")</h3>
                            <small class="text-muted">@Model.DaysWorked × ₱@Model.Employee?.DailyRate.ToString("N2")</small>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small text-uppercase fw-bold d-block">Total Deductions</label>
                            <h3 class="text-danger fw-bold">₱@Model.Deduction.ToString("N2")</h3>
                            <small class="text-muted invisible">Spacer</small>
                        </div>
                    </div>

                    <div class="my-5 p-4 bg-light rounded-3 border-start border-primary border-5 text-center">
                        <label class="text-primary small text-uppercase fw-bold d-block mb-2">Net Payout</label>
                        <h1 class="display-4 fw-bold text-primary mb-0">₱@Model.NetPay.ToString("N2")</h1>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.PayrollID" class="btn btn-warning px-4 shadow-sm">
                            <i class="bi bi-pencil-square me-2"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.PayrollID" class="btn btn-danger px-4 shadow-sm">
                            <i class="bi bi-trash3 me-2"></i>Delete
                        </a>
                        <button onclick="window.print();" class="btn btn-outline-dark px-4">
                            <i class="bi bi-printer me-2"></i>Print Payslip
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-link text-decoration-none text-muted p-0">
            <i class="bi bi-arrow-left me-1"></i>Back to Payroll List
        </a>
    </div>
</div>

<style>
    /* Printing styles to hide sidebar and header when printing the payslip */
    @@media print {
        #sidebar-wrapper, .top-navbar, .btn, .breadcrumb, .text-muted.extra-small {
            display: none !important;
        }
        #page-content-wrapper { margin: 0; padding: 0; width: 100%; }
        .card { border: 1px solid #ddd !important; box-shadow: none !important; }
        body { background: white !important; }
    }
</style>