@model TechCoreSolutions.Models.Payroll

@{
    ViewData["Title"] = "Edit Payroll";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Edit Payroll Record</h1>
            <br />
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="PayrollID" />

                <div class="mb-3">
                    <label for="EmployeeID" class="form-label">Employee</label>
                    <select id="EmployeeID" name="EmployeeID" class="form-control" required>
                        @foreach (var employee in ViewBag.Employees ?? new List<dynamic>())
                        {
                            <option value="@employee.EmployeeID" selected="@(employee.EmployeeID == Model.EmployeeID)">@employee.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="EmployeeID" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Date" class="form-label"></label>
                    <input asp-for="Date" class="form-control" type="date" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DaysWorked" class="form-label"></label>
                    <input asp-for="DaysWorked" class="form-control" type="number" min="0" max="31" />
                    <span asp-validation-for="DaysWorked" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Deduction" class="form-label"></label>
                    <input asp-for="Deduction" class="form-control" type="number" min="0" step="0.01" />
                    <span asp-validation-for="Deduction" class="text-danger"></span>
                </div>

                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Computed Values</h5>
                        <p class="card-text">
                            <strong>Gross Pay:</strong> ₱ @Model.GrossPay.ToString("N2")<br />
                            <strong>Net Pay:</strong> ₱ @Model.NetPay.ToString("N2")
                        </p>
                    </div>
                </div>
                <br />

                <div class="mb-3">
                    <button type="submit" class="btn btn-success">Update Payroll</button>
                    <a asp-action="ByEmployee" asp-route-id="@Model.EmployeeID" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
